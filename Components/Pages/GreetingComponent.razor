@* GreetingComponent.razor *@
@rendermode InteractiveServer

<div class="greeting-wrapper">

    <h3>Blazor Data Binding Demo</h3>

    <label for="nameInput">Enter your name:</label>

    @* ─── TWO-WAY BINDING ─────────────────────────────────────
       @bind="userName"         → links input VALUE to the C# field
       @bind:event="oninput"   → triggers on every keystroke (live)
       Without @bind:event, it only updates on blur (tab/click away) *@
    <input id="nameInput"
           type="text"
           @bind="userName"
           @bind:event="oninput"
           placeholder="Type your name..."
           class="name-input" />

    @* ─── ONE-WAY BINDING ────────────────────────────────────
       @userName simply renders the current value of the C# field.
       It reads data; it does NOT write back to the variable.
       Blazor re-renders this section automatically when userName changes. *@
    <div class="greeting-display">
        @if (!string.IsNullOrWhiteSpace(userName))
        {
            <p>Hello, @userName! 👋 Welcome to Blazor!</p>
        }
        else
        {
            <p class="placeholder">Start typing your name above...</p>
        }
    </div>

    @* Clear button — demonstrates programmatic two-way update *@
    <button @onclick="ClearName">Clear</button>

</div>

@code {
    // ── C# backing field ──────────────────────────────────────
    // Both binding directions share this single variable.
    // @bind reads AND writes it; @userName only reads it.
    private string userName = string.Empty;

    private void ClearName()
    {
        userName = string.Empty;   // Blazor re-renders automatically
    }
}

<style>
    .greeting-wrapper { max-width: 420px; padding: 2rem; }
    .name-input { width: 100%; padding: 10px; font-size: 16px;
                  border: 1.5px solid #ccc; border-radius: 6px; }
    .greeting-display { margin-top: 1rem; padding: 14px;
                        background: #EDE9FF; border-radius: 8px;
                        min-height: 52px; }
    .placeholder { color: #888; font-style: italic; }
    button { margin-top: 10px; padding: 8px 18px; cursor: pointer; }
</style>